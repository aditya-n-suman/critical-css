# NOTE: no blanket `coverage/` ignore — it collided with source dirs named
# `coverage` (packages/coverage, packages/browser/src/coverage). If test-coverage
# reporting is added, point it at a distinct dir (e.g. `.coverage/`) and ignore that.
.coverage/
*.log
*.tsbuildinfo
.DS_Store

# Stray CLI extraction outputs from manual runs at repo root (regenerable; never source).
/critical-*.css
/critical-*-report.json

# apps/visualizer's generate-sample-data.mjs output (regenerable; never source).
apps/visualizer/.sample-data/
